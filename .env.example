# Backend API Server Configuration

# Server port (default: 3000)
PORT=3000

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:5173

# Email service (Resend)
# Get free API key at https://resend.com
RESEND_API_KEY=your_resend_api_key_here

# Sender email address
FROM_EMAIL=noreply@caacademy.com

# Database (SQLite - no config needed, auto-creates data.db)
# For production, consider migrating to PostgreSQL

# Admin API key for access to admin panel and broadcast endpoints
# Set a strong random value, e.g. a UUID. Keep this secret.
ADMIN_KEY=replace_with_a_strong_value
